# Environment variables template — copy to `.env` (gitignored) and fill in values.
# Never commit real values. Real GCP credentials live in ~/.gcp/, not here.
#
#   cp .env.example .env

# --- Amplitude (product analytics — ADR-0007) -------------------------------
# Project Settings → Projects → <your project> → General. Spark plan, free up to
# 10M events/month. API key for SDK ingestion; secret key for server-side and
# the Export API. Treat the secret key like a password.
AMPLITUDE_API_KEY=
AMPLITUDE_SECRET_KEY=

# --- Sentry (error monitoring for the Dagster process) ----------------------
# sentry.io project → Settings → Client Keys (DSN). Free tier is enough for a
# single-developer project. If unset, sentry_sdk.init becomes a no-op — code
# still runs, errors just don't get reported.
SENTRY_DSN=
